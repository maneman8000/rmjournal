/**
 * For more details on how to configure Wrangler, refer to:
 * https://developers.cloudflare.com/workers/wrangler/configuration/
 */
{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "rmjournal-worker",
	"main": "src/worker.py",
	"compatibility_date": "2026-03-17",
	"compatibility_flags": [
		"python_workers"
	],
	"observability": {
		"enabled": true
	},
	// Cron Triggers
	// https://developers.cloudflare.com/workers/configuration/cron-triggers/
	// - "0 */6 * * *" : sync（6時間ごと）
	// - "0 15 * * *"  : archive ページ生成（UTC 15:00 = JST 0:00）
	"triggers": {
		"crons": [
			"0 */6 * * *",
			"0 15 * * *"
		]
	},
	/**
	 * R2 Bucket Binding
	 * https://developers.cloudflare.com/r2/api/workers/workers-api-usage/
	 */
	"r2_buckets": [
		{
			"binding": "R2_BUCKET",
			"bucket_name": "rmjournal-storage"
		}
	],
	/**
	 * KV Namespace Bindings
	 * https://developers.cloudflare.com/kv/api/
	 */
	"kv_namespaces": [
		{
			"binding": "RMJOURNAL_CACHE",
			"id": "104b86e791004a6bbee33369d38e156b"
		},
		{
			"binding": "RMJOURNAL_AUTH",
			"id": "496077f8a5a9432392a288692197bc20"
		}
	],
	/**
	 * Secrets (登録は wrangler secret put コマンドで行う)
	 * - RM_DEVICE_TOKEN
	 * - RM_USER_TOKEN
	 */

	// Queue bindings (TEST: verify Python Workers queue() handler support)
	// Producer binding for sending render jobs
	// Consumer configured to process messages from the same worker
	"queues": {
		"producers": [
			{
				"binding": "RENDER_QUEUE",
				"queue": "rmjournal-render-queue"
			}
		],
		"consumers": [
			{
				"queue": "rmjournal-render-queue",
				"max_batch_size": 1,
				"max_batch_timeout": 0
			}
		]
	},
	// Extend CPU time for Queue Consumer (TEST)
	"limits": {
		"cpu_ms": 30000
	}
	/**
	 * Smart Placement
	 * https://developers.cloudflare.com/workers/configuration/smart-placement/
	 */
	// "placement": { "mode": "smart" }
}